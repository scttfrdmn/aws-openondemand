# terraform/backend.hcl.example
#
# Copy this file to terraform/backend.hcl, fill in values, then initialise:
#
#   terraform init -backend-config=backend.hcl
#
# backend.hcl is listed in .gitignore — NEVER commit it to Git.
# The state file contains sensitive data (OIDC client secrets, auth tokens).
#
# Use scripts/bootstrap-terraform-backend.sh to create the S3 bucket and
# DynamoDB lock table before running terraform init.

bucket         = "ood-terraform-state-YOUR-ACCOUNT-ID"
key            = "ood/YOUR-ENVIRONMENT/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "ood-terraform-locks-YOUR-ACCOUNT-ID"
